# Produktions-Konfiguration — als .env.production neben die Compose-Datei legen.
# Start: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Domain des Tools. Caddy holt automatisch ein Let's-Encrypt-Zertifikat,
# sobald der DNS-A-Record auf den Server zeigt.
SITE_ADDRESS=tool.corvion.de
ORIGIN=https://tool.corvion.de

# Datenbank (Passwort erzeugen: openssl rand -hex 24)
POSTGRES_PASSWORD=
# Dasselbe Passwort hier direkt eintragen:
DATABASE_URL=postgres://corvion:HIER-DAS-PASSWORT@db:5432/corvion

# Auth (erzeugen: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Erster Admin — einmalig seeden mit:
# docker compose -f docker-compose.prod.yml --env-file .env.production exec app node scripts/seed-admin.mjs
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Drizzle
DATABASE_URL="postgres://corvion:dev-only-password@localhost:5432/corvion"
TEST_DATABASE_URL="postgres://corvion:dev-only-password@localhost:5432/corvion_test"

ORIGIN="http://localhost:5173"

# Better Auth — 32+ Zeichen, z. B. via: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# Seed (nur lokal, erster Admin)
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Microsoft Graph (Stufe 2 Ticketsystem) — siehe docs/entra-id-setup.md
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
SUPPORT_MAILBOX=support@corvion.de
# Mail-Sync: on/off (aus lassen, bis Entra eingerichtet ist)
TICKET_SYNC=off

# Basis-URL für Links in Mails (Einladung/Passwort)
APP_URL=http://localhost:5173

# lexoffice Public API (Stufe 3 Rechnungen) — Key: app.lexoffice.de → Extras → Public API
LEXOFFICE_API_KEY=
LEXOFFICE_SYNC=off
